<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="GenericDeepL"
           Language="1033"
           Codepage="65001"
           Version="1.0.0.0"
           Manufacturer="GenericDeepL"
           UpgradeCode="a1b2c3d4-e5f6-7890-abcd-ef1234567890"
           InstallerVersion="200"
           Compressed="yes"
           Scope="perMachine">
    <SummaryInformation Description="GenericDeepL - DeepL-style translation application"
                         Comments="GenericDeepL installer" />
    <WixVariable Id="WixUILicenseRtf" Value="license.rtf" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of GenericDeepL is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="INSTALLFOLDER" Name="GenericDeepL">
        <Component Id="ApplicationFiles" Guid="b1c2d3e4-f5a6-7890-bcde-f12345678901">
          <File Id="GenericDeepL.exe"
                Source="$(var.AppBinPath)GenericDeepL.exe"
                KeyPath="yes" />
          <File Id="GenericDeepL.dll"
                Source="$(var.AppBinPath)GenericDeepL.dll" />
          <File Id="Hardcodet.NotifyIcon.Wpf.dll"
                Source="$(var.AppBinPath)Hardcodet.NotifyIcon.Wpf.dll" />
          <File Id="Newtonsoft.Json.dll"
                Source="$(var.AppBinPath)Newtonsoft.Json.dll" />
          <File Id="GenericDeepL.runtimeconfig.json"
                Source="$(var.AppBinPath)GenericDeepL.runtimeconfig.json" />
          <File Id="GenericDeepL.deps.json"
                Source="$(var.AppBinPath)GenericDeepL.deps.json" />
          <File Id="region_models.json"
                Source="$(var.AppBinPath)region-models.json" />
        </Component>
        <Component Id="StartupRunKey" Guid="d3e4f5a6-b7c8-9012-def0-123456789012" Condition="RUNATSTARTUP">
          <RegistryValue Root="HKCU"
                        Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run"
                        Name="GenericDeepL"
                        Type="string"
                        Value='"[INSTALLFOLDER]GenericDeepL.exe"'
                        KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="GenericDeepL">
        <Component Id="StartMenuShortcut" Guid="c2d3e4f5-a6b7-8901-cdef-123456789012">
          <Shortcut Id="ApplicationStartMenuShortcut"
                    Name="GenericDeepL"
                    Description="GenericDeepL - DeepL-style translation application"
                    Target="[INSTALLFOLDER]GenericDeepL.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Directory="ApplicationProgramsFolder" On="uninstall" />
          <RegistryValue Root="HKCU"
                        Key="Software\GenericDeepL"
                        Name="Installed"
                        Type="integer"
                        Value="1"
                        KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>
    <Feature Id="MainApplication" Title="GenericDeepL" Level="1">
      <ComponentRef Id="ApplicationFiles" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="StartupRunKey" />
    </Feature>
    <UI>
      <ui:WixUI Id="WixUI_Minimal" InstallDirectory="INSTALLFOLDER" />
      <Dialog Id="StartupOptionDlg" Width="370" Height="270" Title="GenericDeepL Setup">
        <Control Id="Title" Type="Text" X="20" Y="20" Width="330" Height="30" NoPrefix="yes" Text="Choose installation options:" />
        <Control Id="RunAtStartupCheckbox" Type="CheckBox" X="20" Y="60" Width="330" Height="17" Property="RUNATSTARTUP" CheckBoxValue="1" Text="Run GenericDeepL at Windows startup" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="Back" />
        <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="Next" />
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel" />
      </Dialog>
      <Publish Dialog="WelcomeEulaDlg" Control="Install" Event="NewDialog" Value="StartupOptionDlg" Order="100" Condition="1" />
      <Publish Dialog="StartupOptionDlg" Control="Back" Event="NewDialog" Value="WelcomeEulaDlg" Condition="1" />
      <Publish Dialog="StartupOptionDlg" Control="Next" Event="NewDialog" Value="VerifyReadyDlg" Condition="1" />
      <Publish Dialog="StartupOptionDlg" Control="Cancel" Event="EndDialog" Value="Exit" Condition="1" />
    </UI>
    <Launch Condition="Installed OR (VersionNT &gt;= 603)" Message="This application requires Windows 10 or later." />
    <Icon Id="ApplicationIcon" SourceFile="$(var.AppBinPath)GenericDeepL.exe" />
    <Property Id="ARPPRODUCTICON" Value="ApplicationIcon" />
    <Property Id="RUNATSTARTUP" Value="1" />
  </Package>
</Wix>
