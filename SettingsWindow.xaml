<Window x:Class="GenericDeepL.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="500" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Label Grid.Row="0" Content="Google Vertex AI API Key:" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <PasswordBox x:Name="ApiKeyPasswordBox" Grid.Row="1" Margin="0,0,0,20" PasswordChar="*"/>

        <Label Grid.Row="2" Content="Region:" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <ComboBox x:Name="RegionComboBox" Grid.Row="3" Margin="0,0,0,20"/>

        <Label Grid.Row="4" Content="Model:" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <ComboBox x:Name="ModelComboBox" Grid.Row="5" Margin="0,0,0,20"/>

        <Label Grid.Row="6" Content="翻訳スタイル:" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <StackPanel Grid.Row="7" Margin="0,0,0,20">
            <RadioButton x:Name="StyleStandard" Content="標準" GroupName="TranslationStyle" Margin="0,5,0,0" IsChecked="True"/>
            <RadioButton x:Name="StyleCasual" Content="カジュアル" GroupName="TranslationStyle" Margin="0,5,0,0"/>
            <RadioButton x:Name="StyleFormal" Content="フォーマル" GroupName="TranslationStyle" Margin="0,5,0,0"/>
            <RadioButton x:Name="StyleLiteral" Content="厳密な直訳" GroupName="TranslationStyle" Margin="0,5,0,0"/>
            <RadioButton x:Name="StyleNatural" Content="自然さを優先した翻訳" GroupName="TranslationStyle" Margin="0,5,0,0"/>
        </StackPanel>

        <CheckBox x:Name="StartupCheckBox" Grid.Row="8" Content="Windows起動時に自動実行" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Save" Width="80" Height="30" Margin="0,0,10,0" Click="SaveButton_Click"/>
            <Button Content="Cancel" Width="80" Height="30" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
