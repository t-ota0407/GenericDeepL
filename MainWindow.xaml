<Window x:Class="GenericDeepL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GenericDeepL"
        mc:Ignorable="d"
        Title="GenericDeepL" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_Settings" Click="SettingsMenuItem_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="ExitMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左側：原文 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Content="原文" FontWeight="Bold" Padding="10,5" Background="#F0F0F0"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <TextBox x:Name="OriginalTextBox" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             Padding="10"
                             VerticalContentAlignment="Top"
                             HorizontalContentAlignment="Left"
                             Text="原文がここに表示されます..."/>
                </ScrollViewer>
            </Grid>

            <!-- 区切り線 -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="LightGray"/>

            <!-- 右側：翻訳結果 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- ラベルと翻訳中インジケーター -->
                <Grid Grid.Row="0" Background="#F0F0F0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="翻訳結果" FontWeight="Bold" Padding="10,5"/>
                    
                    <!-- 翻訳中の表示 -->
                    <TextBlock x:Name="TranslatingIndicator" 
                               Grid.Column="2" 
                               Text="翻訳中..." 
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               FontWeight="SemiBold"
                               Foreground="#0066CC"
                               FontSize="12"
                               Visibility="Collapsed"/>
                </Grid>
                
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <TextBox x:Name="TranslationTextBox" 
                             TextWrapping="Wrap" 
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             Padding="10"
                             VerticalContentAlignment="Top"
                             HorizontalContentAlignment="Left"
                             Text="翻訳結果がここに表示されます..."/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
